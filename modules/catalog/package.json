{
  "name": "@nbcp/catalog",
  "version": "0.1.0",
  "private": true,
  "description": "NBCP Catalog Shared module — commercial offerings, variants, list prices (S2)",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
