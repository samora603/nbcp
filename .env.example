# Environment variable template
#
# Copy to `.env` for local use when application packages exist.
# Never commit real secrets.
#
# Phase 0.1: placeholder keys only — applications are not scaffolded yet.

# Node
NODE_ENV=development

# Database (Supabase Postgres connection string — replace when available)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Redis
# REDIS_URL=redis://localhost:6379

# Application
# PORT=3000
